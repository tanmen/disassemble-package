{
  "name": "disassemble-package",
  "version": "0.0.0",
  "description": "Separate the config contained in package.json into a file.",
  "type": "module",
  "main": "index.js",
  "homepage": "https://github.com/tanmen/disassemble-package#readme",
  "repository": "https://github.com/tanmen/disassemble-package",
  "funding": "https://github.com/sponsors/tanmen",
  "author": "tanmen",
  "license": "MIT",
  "keywords": [
    "package",
    "package.json",
    "disassemble",
    "separate",
    "decompose"
  ],
  "bin": {
    "disassemble-package": "cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src",
    "postinstall": "husky && typesync && yarn check --integrity || yarn install --ignore-scripts && yarn-deduplicate",
    "prepublishOnly": "pinst --disable",
    "postpublish": "pinst --enable",
    "presemantic-release": "yarn build && cp package.json README.md LICENSE dist",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "command-line-args": "^6.0.2",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@types/command-line-args": "^5.0.0",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/lint-staged": "^14.0.0",
    "@types/node": "^25.8.0",
    "@types/semantic-release": "^21.1.0",
    "eslint": "^10.4.0",
    "globals": "^16.0.0",
    "husky": "^9.0.1",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.0",
    "pinst": "^3.0.0",
    "semantic-release": "^25.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "typesync": "^0.14.0",
    "yarn-deduplicate": "^6.0.0"
  }
}
